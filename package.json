{
  "name": "theokit-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck.only --run",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "build": "pnpm -r run build",
    "validate:publint": "npx publint packages/theo && npx publint packages/create-theo",
    "validate:attw": "npx @arethetypeswrong/cli --pack packages/theo --ignore-rules cjs-resolves-to-esm no-resolution",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "knip:strict": "knip --strict",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:audit": "pnpm audit --prod --audit-level=high",
    "check:bundle": "bash scripts/check-bundle-budget.sh",
    "check:deps": "dependency-cruiser packages/theo/src --config .dependency-cruiser.cjs",
    "check:naming": "ls-lint",
    "check:all": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:coverage && pnpm knip && pnpm check:licenses && pnpm check:audit",
    "try:scaffold": "tsx packages/create-theo/src/cli.ts my-test",
    "try:dev": "cd my-test && npx tsx ../packages/theo/src/cli/index.ts dev",
    "try:clean": "node -e \"const fs=require('fs');fs.rmSync('my-test',{recursive:true,force:true})\"",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm sync:templates",
    "release": "pnpm build && changeset publish",
    "prepare": "git config core.hooksPath .githooks || true",
    "check:secrets": "bash scripts/prevent-secrets.sh",
    "sync:templates": "node scripts/sync-template-versions.mjs --write",
    "check:templates": "node scripts/sync-template-versions.mjs",
    "theo-ui:link": "bash scripts/theo-ui-link.sh",
    "theo-ui:unlink": "bash scripts/theo-ui-unlink.sh"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9",
    "@ls-lint/ls-lint": "^2.3.1",
    "@playwright/test": "^1.52.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@usetheo/sdk": "workspace:*",
    "@vitest/coverage-v8": "^3",
    "autocannon": "^8.0.0",
    "better-sqlite3": "^12.10.0",
    "db0": "^0.3.0",
    "dependency-cruiser": "^17.4.2",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-promise": "^7",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-security": "^3",
    "eslint-plugin-sonarjs": "^3.0.7",
    "eslint-plugin-unicorn": "^56",
    "eslint-plugin-unused-imports": "^4",
    "expect-type": "^1.1.0",
    "globals": "^15",
    "knip": "^5",
    "lint-staged": "^15",
    "pg-mem": "^3.0.14",
    "postgres": "^3.4.9",
    "prettier": "^3",
    "publint": "^0.3.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "unstorage": "^1.10.0",
    "vitest": "^3.0.0",
    "ws": "^8.20.1",
    "yaml": "^2.8.4",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.25.76"
    }
  }
}
