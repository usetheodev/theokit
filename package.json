{
  "name": "theo-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck.only --run",
    "test:e2e": "playwright test --config playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "try:scaffold": "tsx packages/create-theo/src/cli.ts my-test",
    "try:dev": "cd my-test && npx tsx ../packages/theo/src/cli/index.ts dev",
    "try:clean": "node -e \"const fs=require('fs');fs.rmSync('my-test',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "expect-type": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
