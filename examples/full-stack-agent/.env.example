# OpenRouter API key — get one at https://openrouter.ai
# Format: sk-or-v1-...
OPENROUTER_API_KEY=

# Anthropic key — optional fallback if OPENROUTER_API_KEY is not set.
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# Telegram bot token — optional. Get one from @BotFather on Telegram.
# Required only if you run `pnpm bot`.
TELEGRAM_BOT_TOKEN=

# Override the default web_fetch allowlist. Comma-separated hostnames.
# Default: wikipedia.org,github.com,raw.githubusercontent.com,api.github.com,news.ycombinator.com,html.duckduckgo.com
WEB_FETCH_ALLOWLIST=

# Override the model used by both web + Telegram. Default:
#   openrouter/anthropic/claude-3.5-sonnet (when OPENROUTER_API_KEY set)
#   claude-sonnet-4-5-20250929              (when ANTHROPIC_API_KEY set)
# MODEL_ID=openrouter/openai/gpt-4o
