{
  "name": "agent-saas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "theokit dev",
    "build": "theokit build",
    "start": "theokit start",
    "db:up": "docker run -d --name agent-saas-pg -p 5432:5432 -e POSTGRES_USER=user -e POSTGRES_PASSWORD=pass -e POSTGRES_DB=agent_saas_dev postgres:16-alpine",
    "db:down": "docker rm -f agent-saas-pg",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@usetheo/ui": "^0.1.0-next.0",
    "drizzle-orm": "^0.45.0",
    "hash-wasm": "^4.12.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "theokit": "workspace:*",
    "ws": "^8.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.0",
    "postcss": "^8.5.14",
    "tailwindcss": "3",
    "typescript": "^5.7.0"
  }
}
