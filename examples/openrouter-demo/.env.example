# Get your key at https://openrouter.ai/keys
# Free tier available; pay-as-you-go for production usage.
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — defaults to openai/gpt-4o-mini (cheap + tool-calling capable).
# Other options:
#   openrouter/anthropic/claude-haiku-4.5      (Anthropic family)
#   openrouter/google/gemini-2.0-flash-001     (cheapest tier)
#   openrouter/anthropic/claude-sonnet-4.5     (premium quality)
#   openrouter/meta-llama/llama-3.3-70b-instruct (open weights)
# MODEL_ID=openrouter/openai/gpt-4o-mini

# Production: session encryption key. Required when NODE_ENV=production.
# Generate: openssl rand -hex 32
# SESSION_SECRET=
