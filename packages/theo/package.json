{
  "name": "theokit",
  "version": "0.1.0-alpha.5",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsup"
  },
  "bin": {
    "theokit": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./react-query": {
      "types": "./dist/react-query/index.d.ts",
      "import": "./dist/react-query/index.js"
    },
    "./adapters/web-shim": {
      "types": "./dist/adapters/web-shim.d.ts",
      "import": "./dist/adapters/web-shim.js"
    },
    "./adapters/ws-shim": {
      "types": "./dist/adapters/ws-shim.d.ts",
      "import": "./dist/adapters/ws-shim.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.0",
    "busboy": "^1.6.0",
    "cac": "^6.7.14",
    "goober": "^2.1.16",
    "superjson": "^2.2.6",
    "tsx": "^4.19.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "ws": "^8.20.1",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4"
  }
}
